# =====================================
# GeoVision3D Environment Configuration
# Seli Kasela Creative Studio
# =====================================

# SERVER
PORT=8080
ENVIRONMENT=production

# =====================================
# GOOGLE MAPS
# =====================================

GOOGLE_MAPS_API_KEY=xxxxx

# =====================================
# OPENWEATHER (OPTIONAL)
# =====================================

OPENWEATHER_API_KEY=xxxxx

# =====================================
# OPENCAGE GEOCODING
# =====================================

OPENCAGE_API_KEY=xxxx

# =====================================
# GEOLOCATION
# =====================================

DEFAULT_LATITUDE=-8.7933893
DEFAULT_LONGITUDE=115.1227501

DEFAULT_CITY=Badung
DEFAULT_COUNTRY=Indonesia

# =====================================
# ASN / NETWORK
# =====================================

DEFAULT_IP=103.137.82.147
DEFAULT_ASN=AS138828

# =====================================
# BRANDING
# =====================================

APP_NAME=GeoVision3D
APP_OWNER=Seli Kasela
APP_ORG=Seli Kasela Creative Studio

# =====================================
# SECURITY
# =====================================

ENABLE_CORS=true
ENABLE_LOGGING=true

# =====================================
# MAP SETTINGS
# =====================================

DEFAULT_ZOOM=18
DEFAULT_TILT=45
DEFAULT_HEADING=0

# =====================================
# OPTIONAL DEPLOYMENT
# =====================================

DOMAIN=selikasela.cyou

# =====================================
# OPTIONAL OSM
# =====================================

OSM_TILE_SERVER=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
