# =====================================
# GeoVision3D .gitignore
# =====================================

# ENV FILES
.env
.env.local
.env.production

# LOG FILES
*.log

# BUILD FILES
*.exe
*.exe~
*.dll
*.so
*.dylib

# GO BUILD
bin/
dist/

# GO MODULES
vendor/

# IDE
.vscode/
.idea/

# OS FILES
.DS_Store
Thumbs.db

# NODE
node_modules/

# TEMP FILES
tmp/
temp/

# CACHE
.cache/

# TEST OUTPUT
coverage.out

# DOCKER
docker-compose.override.yml

# CERTIFICATES
*.pem
*.key
*.crt

# MAP API SECRETS
google-maps-key.txt
api-keys.json

# STATIC GENERATED FILES
static/assets/generated/

# RAILWAY / RENDER
.railway/
.render/

# CLOUD
.vercel/
.netlify/

# LOCAL DATABASES
*.db
*.sqlite

# GEO DATA
*.geojson.tmp

# MAC
.AppleDouble
.LSOverride

# LINUX
*~

# WINDOWS
Desktop.ini

# =====================================
# END
# =====================================
